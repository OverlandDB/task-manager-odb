PORT=3000
NODE_ENV=production

# Render-managed Postgres connection string. Use the internal hostname for
# services in the same Render region (no SSL required); use the external
# hostname elsewhere (SSL required, handled automatically).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stable secret for signing JWT-like session tokens. If unset, a random secret
# is generated per process and ALL sessions are invalidated on restart.
# Must be the SAME value across every *.overlanddesignbuild.com app that
# wants to share the auth cookie (kb, erp, etc.).
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth credentials from console.cloud.google.com → APIs & Services →
# Credentials. The redirect URI must match what's registered there exactly.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=https://tasks.overlanddesignbuild.com/auth/google/callback

# Cookie domain for the auth_token cookie. Setting this to .overlanddesignbuild.com
# scopes the session to ALL subdomains so future apps (kb., erp., etc.) share
# the login. Leave unset for local dev — browsers default to host-only.
COOKIE_DOMAIN=.overlanddesignbuild.com

# Workspace domain to restrict sign-in to. Defaults to overlanddesignbuild.com.
ALLOWED_EMAIL_DOMAIN=overlanddesignbuild.com
